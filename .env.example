# Copied to ~/.config/cc-litellm/.env by install.sh.
# Local-only install: Claude talks to localhost:4000; LiteLLM talks to these providers.

# Azure AI Foundry / Azure OpenAI
AZURE_AI_FOUNDRY_API_KEY=your-azure-ai-foundry-api-key
AZURE_AI_FOUNDRY_KIMI_API_BASE=https://your-resource.cognitiveservices.azure.com/models
AZURE_AI_FOUNDRY_NANO_API_BASE=https://your-resource.cognitiveservices.azure.com/
AZURE_AI_FOUNDRY_API_VERSION=2025-04-01-preview

# Backward-compat aliases. install.sh can copy these into the new names.
AZURE_AI_API_KEY=your-azure-ai-api-key
AZURE_AI_API_BASE=https://your-resource.openai.azure.com/

# Local LiteLLM auth token. Any local secret string is fine.
LITELLM_MASTER_KEY=sk-proxy-local
DISABLE_ADMIN_UI=true

# Z.ai (Zhipu AI) API Key
# LiteLLM config.yaml expects ZAI_API_KEY for the GLM models.
ZAI_API_KEY=your-zai-api-key

# Backward-compat: older setups used ZHIPU_API_KEY.
ZHIPU_API_KEY=your-zhipu-api-key

# Optional ChatGPT browser provider via CodeWebChat.
# Load the CodeWebChat browser extension in a logged-in chatgpt.com tab, then
# request model chatgpt-browser. The default embedded bridge exposes the
# CodeWebChat-compatible WebSocket endpoint from this Docker stack.
CHATGPT_BROWSER_MODEL=chatgpt-browser
CHATGPT_BROWSER_API_BASE=http://chatgpt-browser-proxy:8080/v1
CHATGPT_BROWSER_API_KEY=sk-chatgpt-browser-local
CHATGPT_BROWSER_WS_URL=embedded
CHATGPT_BROWSER_WS_TOKEN=gemini-coder-vscode
CHATGPT_BROWSER_EXTENSION_WS_TOKEN=gemini-coder
CHATGPT_BROWSER_REQUEST_TIMEOUT=300
CHATGPT_BROWSER_CONNECT_TIMEOUT=10
CHATGPT_BROWSER_PING_INTERVAL=10
CHATGPT_BROWSER_NEW_SESSION_PER_REQUEST=0
CHATGPT_BROWSER_COMPACT_EVERY=30
CHATGPT_BROWSER_SESSION_STATE_PATH=/data/session_state.json
CHATGPT_BROWSER_TARGET_BROWSER_ID=

# Optional browser-JS API provider. The CodeWebChat Chrome extension performs
# fetch() to chatgpt.com/backend-api with the logged-in browser session.
CHATGPT_BROWSER_JS_MODEL=chatgpt-browser-js
CHATGPT_BROWSER_JS_API_MODE=conversation
CHATGPT_BROWSER_JS_UPSTREAM_MODEL=auto
CHATGPT_BROWSER_JS_API_URL=https://chatgpt.com/backend-api/conversation

# Optional direct API provider via icebear0828/codex-proxy.
# This uses Codex/ChatGPT OAuth from CODEX_HOME/auth.json and exposes model
# chatgpt-browser-api. It supports native OpenAI tool_calls better than the DOM
# browser route. Import the token after startup with:
#   bash scripts/import_codex_oauth.sh
CHATGPT_BROWSER_API_DIRECT_BASE=http://codex-oauth-proxy:8080/v1
CHATGPT_BROWSER_API_DIRECT_KEY=pwd
