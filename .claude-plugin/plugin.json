{
  "name": "cc-litellm",
  "version": "1.1.5",
  "description": "Automatically falls back to Azure AI (via LiteLLM) when Anthropic credits are exhausted. Zero overhead during normal usage.",
  "author": {
    "name": "your-username",
    "url": "https://github.com/your-username"
  },
  "repository": "https://github.com/your-username/cc-litellm",
  "license": "MIT",
  "keywords": [
    "fallback",
    "azure",
    "credits",
    "proxy",
    "litellm"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session_start.sh",
            "timeout": 8000,
            "suppressOutput": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "billing_error|credit_balance|overloaded|rate_limit|usage_limit|limit_reached|capacity",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/billing_error.sh",
            "timeout": 130000,
            "suppressOutput": true
          }
        ]
      }
    ]
  },
  "skills": "./skills/"
}
