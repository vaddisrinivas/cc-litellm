{
  "name": "cc-litellm",
  "version": "1.1.6",
  "description": "Routes Claude Code / claude -p through a local LiteLLM proxy backed by Azure AI Foundry.",
  "author": {
    "name": "your-username",
    "url": "https://github.com/your-username"
  },
  "repository": "https://github.com/your-username/cc-litellm",
  "license": "MIT",
  "keywords": [
    "claude",
    "local",
    "foundry",
    "azure",
    "glm",
    "kimi",
    "proxy",
    "litellm"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session_start.sh",
            "timeout": 8000,
            "suppressOutput": true
          }
        ]
      }
    ]
  },
  "skills": "./skills/"
}
